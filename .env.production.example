# Production example
ENVIRONMENT=production
DEBUG=False
APP_BASE_URL=https://blog.example.com
ALLOWED_HOSTS=blog.example.com,www.blog.example.com

SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
SESSION_REFRESH_EXPIRE_HOURS=12

COOKIE_SECURE=True
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=.blog.example.com

DATABASE_URL=postgresql+asyncpg://async_blog:replace-db-password@db:5432/async_blog
REDIS_URL=redis://redis:6379/0
RABBITMQ_URL=amqp://blog:replace-rabbitmq-password@rabbitmq:5672//
CELERY_BROKER_URL=amqp://blog:replace-rabbitmq-password@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/1

MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=mailer@example.com
MAIL_PASSWORD=replace-mail-password
MAIL_FROM=mailer@example.com
MAIL_TLS=True
MAIL_SSL=False

ENABLE_REGISTRATION=True
REQUIRE_EMAIL_VERIFICATION=True

ADMIN_EMAIL=owner@example.com
ADMIN_USERNAME=owner
ADMIN_PASSWORD=replace-admin-password
